# Isaac Sim + ROS
ISAAC_SIM_PYTHON=${HOME}/isaacsim/python.sh
ROS_DISTRO=jazzy
ROS_ROOT=/opt/ros/${ROS_DISTRO}
ROS_SETUP_SCRIPT=${ROS_ROOT}/setup.bash
ROS_SETUP_ZSH=${ROS_ROOT}/setup.zsh
ROS_PYTHON_SITE_PACKAGES=${ROS_ROOT}/lib/python3.12/site-packages
PIPELINE_CLEAN_PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Map (USDZ from 3DGRUT) - required
DEFAULT_MAP_PATH=

# Optional mesh (nvblox)
MESH_PATH=
MESH_MODE=skip   # auto | skip
MESH_USD_CACHE_DIR=
MESH_PRIM_PATH=/World/NvbloxMesh
MESH_OFFSET=0,0,0
MESH_ROT=0,0,0
MESH_SCALE=1,1,1
SAVE_MAP_PATH=
MESH_FORCE_CONVERT=0


# Omniverse
OMNI_SERVER=omniverse://<server_ip>
OMNI_USER=omniverse
OMNI_PASS=costnav123

# Robot
ROBOT_USD_PATH=${OMNI_SERVER}/Users/worv/costnav/SegwayE1/Segway_E1_ROS2.usdc
ROBOT_SPAWN_POS="0.0, 0.0, 0.0"
ROBOT_SPAWN_QUAT=
ROBOT_SPAWN_ROT=
ROBOT_SPAWN_YAW=

# Teleop
TELEOP_MODE=joystick
JOYSTICK_BY_ID_DIR=/dev/input/by-id
JOYSTICK_DEV_GLOB=/dev/input/js*
XBOX_ID=
JOYSTICK_TELEOP_CONFIG=
JOYSTICK_TELEOP_CMD=
KEYBOARD_TELEOP_CMD="ros2 run teleop_twist_keyboard teleop_twist_keyboard"

# Capture (Isaac Sim → frames)
CAPTURE_DIR=
CAPTURE_CAMERA_PATH=/World/Segway_E1_ROS2/base_link/sensor_link/rgb_left
CAPTURE_RES=1920,1080
CAPTURE_EVERY=1
CAPTURE_MAX_FRAMES=0

# Fixer (frames → enhanced frames → video)
FIXER_SOURCE_PATH=
FIXER_GIT_URL=https://github.com/nv-tlabs/Fixer.git
FIXER_GIT_REF=main
FIXER_HF_REPO=nvidia/Fixer
FIXER_MODELS_DIR=
FIXER_MODEL_HOST_PATH=
FIXER_CONTAINER_WORKDIR=/work
FIXER_CONTAINER_INPUT_DIR=/input
FIXER_MODEL_PATH=/work/models/pretrained/pretrained_fixer.pkl
FIXER_DOCKER_IMAGE=fixer-cosmos-env
FIXER_DOCKER_CONTEXT=
FIXER_DOCKERFILE=Dockerfile.cosmos
FIXER_FPS=24
FIXER_TIMESTEP=250
AUTO_FIXER_SETUP=1
FIXER_INPUT_DIR=
FIXER_OUT_DIR=

# Optional: auto save map after mesh import
SAVE_MAP_ON_START=0

# Optional: run Fixer after Isaac Sim closes
RUN_FIXER_TO_VIDEO=0
