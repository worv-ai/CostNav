# Model Worker Configuration
COMPOSE_PROJECT_NAME="model_worker-${USER}"
MODEL_WORKER_PORT=8200

# Docker and Version Configuration
CANVAS_VERSION=latest

# Model Configuration - Change this to switch between different models
MODEL_PATH="<path_to_model>" # ex) your-project-root/checkpoints/canvas-costnav

# This will be ignored by slurm sbatch
CUDA_VISIBLE_DEVICES=0
